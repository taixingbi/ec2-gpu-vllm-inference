# Inference model (pick one you can fit on A10G 24GB)
INFER_MODEL=Qwen/Qwen2.5-7B-Instruct

# vLLM image: official (default) or NGC PyTorch for driver compatibility
VLLM_IMAGE=vllm/vllm-openai:cu130-nightly
# VLLM_IMAGE=nvcr.io/nvidia/pytorch:25.01-py3

# Set to 1 when using NGC image (runs pip install vllm on startup)
VLLM_USE_NGC=0

# Optional (only if model is gated)
HUGGING_FACE_HUB_TOKEN=
